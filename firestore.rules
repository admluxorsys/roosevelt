rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Counters — readable/writable by authenticated users (sequential ID generation)
    match /counters/{counterId} {
      allow read, write: if request.auth != null;
    }

    // Kanban groups and their cards
    match /kanban-groups/{groupId} {
      allow read, write: if request.auth != null;

      match /cards/{cardId} {
        allow read, write: if request.auth != null;
      }
    }

    match /cards/{cardId} {
      allow read, write: if true;
    }

    match /chatbots/{chatbotId} {
      allow read, write: if true;

      match /pages/{pageId} {
        allow read, write: if true;
      }
    }

    // Web projects: allow read for anyone to enable public previews
    match /web-projects/{projectId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // CRM Contacts — authenticated users can read/write; public can read (for application form)
    match /contacts/{contactId} {
      allow read, write: if request.auth != null;
      allow read: if true;
    }

    // Specific rules for isolated tenant data
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /entities/{entityId}/{document=**} {
         allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Catch-all for authenticated users
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
